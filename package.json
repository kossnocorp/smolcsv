{
  "name": "smolcsv",
  "version": "0.1.0",
  "description": "Smol csv parser and stringifier for the browser, web workers and Node.js",
  "type": "module",
  "main": "index.cjs",
  "module": "index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      },
      "import": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    },
    "./types": {
      "require": {
        "types": "./types.d.cts",
        "default": "./types.cjs"
      },
      "import": {
        "types": "./types.d.ts",
        "default": "./types.js"
      }
    },
    "./delimiter": {
      "require": {
        "types": "./delimiter/index.d.cts",
        "default": "./delimiter/index.cjs"
      },
      "import": {
        "types": "./delimiter/index.d.ts",
        "default": "./delimiter/index.js"
      }
    },
    "./parse": {
      "require": {
        "types": "./parse/index.d.cts",
        "default": "./parse/index.cjs"
      },
      "import": {
        "types": "./parse/index.d.ts",
        "default": "./parse/index.js"
      }
    },
    "./stringify": {
      "require": {
        "types": "./stringify/index.d.cts",
        "default": "./stringify/index.cjs"
      },
      "import": {
        "types": "./stringify/index.d.ts",
        "default": "./stringify/index.js"
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:internal": "oxnode benchmarks/internal.ts",
    "bench:comparison": "oxnode benchmarks/comparison.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kossnocorp/smolcsv.git"
  },
  "keywords": [
    "tiny",
    "csv",
    "browser",
    "workers",
    "web workers"
  ],
  "author": "Sasha Koss <koss@nocorp.me>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kossnocorp/smolcsv/issues"
  },
  "homepage": "https://github.com/kossnocorp/smolcsv#readme",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.16.2",
    "@babel/cli": "^7.24.1",
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-modules-commonjs": "^7.24.1",
    "@babel/preset-env": "^7.24.4",
    "@babel/preset-typescript": "^7.24.1",
    "@oxc-node/cli": "^0.0.35",
    "@parcel/watcher": "^2.4.1",
    "@swc/core": "^1.4.13",
    "@types/sinonjs__fake-timers": "^8.1.5",
    "babel-plugin-replace-import-extension": "^1.1.4",
    "benny": "^3.7.1",
    "bytes-iec": "^3.1.1",
    "csv": "^6.4.1",
    "fast-csv": "^5.0.5",
    "glob": "^10.3.12",
    "minimatch": "^10.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "picocolors": "^1.0.0",
    "typescript": "^5.5.4",
    "vitest": "^1.4.0"
  }
}
